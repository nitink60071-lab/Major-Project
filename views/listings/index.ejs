      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Iconic cities' ">
        <a><i class="fa-solid fa-mountain-city"></i></a>
        <p>Iconic cities</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Castles' ">
        <a><i class="fa-brands fa-fort-awesome"></i></a>
        <p>Castles</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Mountains' ">
        <a><i class="fa-solid fa-mountain-sun"></i></a>
        <p>Mountains</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Amazing pools' ">
        <a><i class="fa-solid fa-person-swimming"></i></a>
        <p>Amazing pools</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Camping' ">
        <a><i class="fa-solid fa-tents"></i></a>
        <p>Camping</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Farms' ">
        <a><i class="fa-solid fa-seedling"></i></a>
        <p>Farms</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Arctic' ">
        <a><i class="fa-solid fa-snowflake"></i></a>
        <p>Arctic</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Domes' ">
        <a><i class="fa-solid fa-igloo"></i></a>
        <p>Domes</p>
      </div>
      <div class="filter" onclick="window.location.href='/listings/category/Boats' ">
        <a><i class="fa-solid fa-ship"></i></a>
        <p>Boats</p>
      </div>

      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
        <input 
        class="form-check-input" 
        type="checkbox" 
        role="switch" 
        id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Price incl. taxes</label>
</div>
      </div>

    </div>
    <div id="listings-container" class="row row-cols-lg-3 row-cols-md-2 mt-3">
        <% for(let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
    <div class="card col listing-card">
  <img 
    src="<%= listing.image.url %>" 
    class="card-img-top" 
    alt="listing_image" 
    style="height: 20rem;"
    />
    <div class="card-img-overlay"></div>

  <div class="card-body">
    <p class="card-text">
        <b><%= listing.title %></b> <br>
        &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
        <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
    </p>
  </div>
</div>
<% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo) {
      if(info.style.display != "inline"){
      info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  })
</script>


<script>
const searchInput = document.querySelector(".search-inp");
const form = searchInput.closest("form");

form.addEventListener("submit", (e) => {
    e.preventDefault();
});

let debounceTimer;

searchInput.addEventListener("input", (e) => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
        let q = e.target.value.trim();
        
        if(!document.getElementById("listings-container")) return;
        
        let container = document.getElementById("listings-container");
        
        try {
            let response = await fetch(`/listings/api/search?q=${encodeURIComponent(q)}`);
            let listings = await response.json();
            
            if(listings.length === 0) {
                container.innerHTML = `
                    <div class="col-12 text-center mt-5">
                        <h4>No listings found for "${q}"</h4>
                    </div>`;
                return;
            }
            
            container.innerHTML = listings.map(listing => `
                <div class="col">
                    <a href="/listings/${listing._id}" class="listing-link">
                        <div class="card col listing-card">
                            <img src="${listing.image.url}"
                                class="card-img-top"
                                alt="listing_image"
                                style="height: 20rem;">
                            <div class="card-img-overlay"></div>
                            <div class="card-body">
                                <p class="card-text">
                                    <b>${listing.title}</b><br>
                                    &#8377;${listing.price.toLocaleString("en-IN")} / night
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            `).join("");
            
        } catch(err) {
            console.log("Search error:", err);
        }
    }, 300);
});
</script>

