<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter {
    text-align: center;
    margin-right: 0.5rem;
    margin-top: 1.5rem;
    opacity: 0.7;
    transition: all 0.25s ease;
    padding: 0.4rem 0.6rem;   /* padding kam */
    cursor: pointer;
  }

  .filter:hover {
    opacity: 1;
    transform: translateY(-3px);
}

  .filter p {
    font-size: 0.8rem;
    transition: all 0.3s ease;
  }

  .filter:hover p {
    color: #fe424d;
    font-weight: 600;
    letter-spacing: 0.3px;
  }


  .filter a i {
    transition: all 0.3s ease;
  }

  .filter:hover a i {
    color: #fe424d;
    transform: scale(1.25) rotate(-8deg);
    text-shadow: 0 0 12px rgba(254, 66, 77, 0.35);
  }

  .tax-info {
    display: none;
  }

  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 1rem;
    display: flex;
    align-items: center;
    transition: all 0.3s ease;
    cursor: pointer;
}

.tax-toggle:hover {
    border: 1.5px solid #fe424d;
    box-shadow: 0 4px 15px rgba(254, 66, 77, 0.15);
    transform: translateY(-2px);
    background: rgba(254, 66, 77, 0.03);
}

.tax-toggle:hover .form-check-label {
    color: #fe424d;
    font-weight: 500;
}

.form-check-input:checked {
    background-color: #fe424d !important;
    border-color: #fe424d !important;
}

</style>
<div class="dropdown d-md-none mb-3 mt-3">
  <button class="btn btn-outline-dark" data-bs-toggle="dropdown">
    <i class="fa-solid fa-ellipsis-vertical"></i>
  </button>

  <ul class="dropdown-menu">
    <li><a class="dropdown-item" href="/listings/category/Trending"> <i class="fa-solid fa-fire"></i> Trending</a></li>
    <li><a class="dropdown-item" href="/listings/category/Rooms"> <i class="fa-solid fa-bed"></i> Rooms</a></li>
    <li><a class="dropdown-item" href="/listings/category/Iconic cities"> <i class="fa-solid fa-mountain-city"></i> Iconic cities</a></li>
    <li><a class="dropdown-item" href="/listings/category/Castles"> <i class="fa-brands fa-fort-awesome"></i> Castles</a></li>
    <li><a class="dropdown-item" href="/listings/category/Mountains"> <i class="fa-solid fa-mountain-sun"></i> Mountains</a></li>
    <li><a class="dropdown-item" href="/listings/category/Amazing pools"> <i class="fa-solid fa-person-swimming"></i> Amazing pools</a></li>
    <li><a class="dropdown-item" href="/listings/category/Camping"> <i class="fa-solid fa-tents"></i> Camping</a></li>
    <li><a class="dropdown-item" href="/listings/category/Farms"> <i class="fa-solid fa-seedling"></i> Farms</a></li>
    <li><a class="dropdown-item" href="/listings/category/Arctic"> <i class="fa-solid fa-snowflake"></i> Arctic</a></li>
    <li><a class="dropdown-item" href="/listings/category/Domes"> <i class="fa-solid fa-igloo"></i> Domes</a></li>
    <li><a class="dropdown-item" href="/listings/category/Boats"> <i class="fa-solid fa-ship"></i> Boats</a></li>
  </ul>
</div>



    <div id="filters" class="d-none d-md-flex">
      <div class="filter" onclick="window.location.href='/listings/category/Trending' ">
        <a><i class="fa-solid fa-fire"></i></a>
